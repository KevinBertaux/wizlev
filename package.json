{
  "name": "wizlev",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/write-build-info.mjs",
    "build:e2e": "vite build --mode e2e && node scripts/write-build-info.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:release": "playwright test --reporter=line",
    "check:brand": "node scripts/check-brand.mjs",
    "check:breakpoints": "node scripts/check-breakpoints.mjs",
    "check:routes": "node scripts/check-routes.mjs",
    "check:storage-keys": "node scripts/check-storage-keys.mjs",
    "check:px-values": "node scripts/check-px-values.mjs",
    "check:spacing": "npm run check:px-values",
    "lighthouse:ci": "node scripts/run-lhci.mjs",
    "qa:release": "npm run check:brand && npm run check:routes && npm run check:storage-keys && npm run check:legal && npm run check:env && npm run check:breakpoints && npm run check:px-values && npm test -- --coverage && npm run test:e2e:release && npm run build && npm run lighthouse:ci",
    "validate:symmetry-shapes": "node scripts/validate-symmetry-shapes.mjs",
    "check:env": "node scripts/check-env.mjs",
    "check:legal": "node scripts/check-legal.mjs"
  },
  "dependencies": {
    "@fontsource/lexend": "^5.2.11",
    "@fontsource/nunito": "^5.2.7",
    "@tailwindcss/vite": "^4.2.1",
    "jszip": "^3.10.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.3",
    "tailwindcss": "^4.2.1",
    "vite": "^5.2.0",
    "vitest": "^2.1.8"
  }
}
