# Studio-ops access (front-only protection)
# Important: this is not server-grade security because the app is client-side.
# Generate SHA-256 hash example (PowerShell):
# $text = 'CHANGE_ME_STRONG_PASSWORD'; $bytes = [Text.Encoding]::UTF8.GetBytes($text); $hash = [Security.Cryptography.SHA256]::Create().ComputeHash($bytes); -join ($hash | ForEach-Object { $_.ToString('x2') })

VITE_ADMIN_USERNAME="kevinbertaux"
VITE_ADMIN_PASSWORD_HASH="e99635f91e227f640d09218dc823f7a284fd9340648e291a599fdefdaf4dbeaf"
VITE_ADMIN_SESSION_TTL_MS="1800000"
VITE_ADMIN_MAX_ATTEMPTS="3"
VITE_ADMIN_BLOCK_MS="1800000"
VITE_ADMIN_HARD_BLOCK_MS="86400000"

# Ads (kept disabled by default, with dummy identifiers until the pro account is ready)
VITE_ADS_PROVIDER="none"
VITE_ADSENSE_CLIENT="ca-pub-0000000000000000"
VITE_ADS_UI_PLACEHOLDERS="false"

# Remote content source (optional, Cloudflare R2 public URL)
# Recommended pattern: one root URL + one folder per module.
VITE_REMOTE_CONTENT_BASE_URL=""

# English vocabulary
VITE_ENGLISH_VOCAB_REMOTE_FOLDER="languages/en/vocabulary"

# French conjugation
VITE_FRENCH_CONJUGATION_REMOTE_FOLDER="languages/fr/conjugation"

# Spanish vocabulary
VITE_SPANISH_VOCAB_REMOTE_FOLDER="languages/es/vocabulary"

# Remote symmetry source (optional, Cloudflare R2 public URL)
VITE_SYMMETRY_REMOTE_FOLDER="math/symmetry"
VITE_SYMMETRY_REMOTE_CONFIG_FILE="shapes-3-points.json"